{
    "name": "mimisk/pinakas",
    "description": ":package_description",
    "license": "MIT",
    "authors": [
        {
            "name": "Mimis K",
            "email": "mimisk88@gmail.com",
            "homepage": "https://mimisk.com"
        }
    ],
    "homepage": "https://github.com/MimisK13/pinakas",
    "keywords": ["Laravel", "Pinakas"],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0|^4.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.36|^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^2.4|^3.0|^4.0",
        "phpunit/phpunit": "^10.5|^11.5|^12.5"
    },
    "autoload": {
        "psr-4": {
            "Mimisk\\Pinakas\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mimisk\\Pinakas\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mimisk\\Pinakas\\PinakasServiceProvider"
            ],
            "aliases": {
                "Pinakas": "Mimisk\\Pinakas\\Facades\\Pinakas"
            }
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "test": "pest",
        "test:coverage": "pest --coverage"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
